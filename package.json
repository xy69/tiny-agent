{
  "name": "tiny-agent-monorepo",
  "private": true,
  "type": "module",
  "workspaces": {
    "packages": [
      "tiny-agent",
      "examples/*"
    ],
    "catalog": {
      "typescript": "^6.0.3",
      "@types/bun": "^1.3.13",
      "prettier": "^3.8.3",
      "tsdown": "^0.22.0",
      "@anthropic-ai/sdk": "^0.95.2",
      "openai": "^6.37.0"
    }
  },
  "devDependencies": {
    "prettier": "catalog:"
  },
  "scripts": {
    "build": "bun run --filter '@xy69/tiny-agent' build",
    "dev": "bun run examples/cli/src/index.ts",
    "dev:web": "bun run examples/web/src/server.ts",
    "typecheck": "bun run --filter '*' typecheck",
    "format": "prettier --write \"tiny-agent/**/*.ts\" \"examples/**/*.ts\""
  }
}
