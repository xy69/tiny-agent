{
  "name": "@xy69/tiny-agent",
  "version": "0.1.0",
  "description": "Tiny, extensible AI agent.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/xy69/tiny-agent"
  },
  "keywords": ["ai", "agent", "llm", "coding-agent", "openai", "anthropic", "tools"],
  "exports": {
    ".": "./packages/core/src/index.ts",
    "./session": "./packages/session/src/index.ts",
    "./providers": "./packages/providers/index.ts",
    "./extensions": "./packages/extensions/index.ts"
  },
  "workspaces": {
    "packages": [
      "packages/*",
      "packages/extensions/*",
      "packages/providers/*",
      "packages/examples/*"
    ],
    "catalog": {
      "typescript": "^6.0.3",
      "@types/bun": "^1.3.13",
      "prettier": "^3.8.3",
      "@anthropic-ai/sdk": "^0.95.2",
      "openai": "^6.37.0"
    }
  },
  "dependencies": {
    "@anthropic-ai/sdk": "catalog:",
    "openai": "catalog:"
  },
  "devDependencies": {
    "typescript": "catalog:",
    "@types/bun": "catalog:",
    "prettier": "catalog:"
  },
  "scripts": {
    "dev": "bun run packages/examples/cli/src/index.ts",
    "dev:web": "bun run packages/examples/web/src/server.ts",
    "typecheck": "bun run --filter '*' typecheck",
    "format": "prettier --write \"packages/**/*.ts\""
  }
}
