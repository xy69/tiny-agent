{
  "name": "@xy69/tiny-agent",
  "version": "0.1.1",
  "description": "Tiny, extensible AI agent.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/xy69/tiny-agent"
  },
  "keywords": ["ai", "agent", "llm", "coding-agent", "openai", "anthropic", "tools"],
  "exports": {
    ".": {
      "bun": "./packages/core/src/index.ts",
      "types": "./dist/core.d.mts",
      "default": "./dist/core.mjs"
    },
    "./session": {
      "bun": "./packages/session/src/index.ts",
      "types": "./dist/session.d.mts",
      "default": "./dist/session.mjs"
    },
    "./providers": {
      "bun": "./packages/providers/index.ts",
      "types": "./dist/providers.d.mts",
      "default": "./dist/providers.mjs"
    },
    "./extensions": {
      "bun": "./packages/extensions/index.ts",
      "types": "./dist/extensions.d.mts",
      "default": "./dist/extensions.mjs"
    }
  },
  "workspaces": {
    "packages": [
      "packages/*",
      "packages/extensions/*",
      "packages/providers/*",
      "packages/examples/*"
    ],
    "catalog": {
      "typescript": "^6.0.3",
      "@types/bun": "^1.3.13",
      "prettier": "^3.8.3",
      "tsdown": "^0.22.0",
      "@anthropic-ai/sdk": "^0.95.2",
      "openai": "^6.37.0"
    }
  },
  "dependencies": {
    "@anthropic-ai/sdk": "catalog:",
    "openai": "catalog:"
  },
  "devDependencies": {
    "@types/bun": "catalog:",
    "prettier": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "bun run packages/examples/cli/src/index.ts",
    "dev:web": "bun run packages/examples/web/src/server.ts",
    "typecheck": "bun run --filter '*' typecheck",
    "format": "prettier --write \"packages/**/*.ts\""
  },
  "files": [
    "dist",
    "packages/*/src",
    "packages/providers",
    "packages/extensions"
  ]
}
